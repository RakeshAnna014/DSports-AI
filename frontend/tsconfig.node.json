{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "outDir": "node_modules/.tsbuild",
    "declarationDir": "node_modules/.tsbuild"
  },
  "include": ["vite.config.ts"]
}
